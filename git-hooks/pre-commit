#!/bin/bash
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
PURPLE='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

ENGINE_URL="http://192.168.133.238:8080"
CHECKER="$(dirname "$0")/../../git-hooks/blind-spot-check.py"
# Fallback path
[ ! -f "$CHECKER" ] && CHECKER="$HOME/chainsight/git-hooks/blind-spot-check.py"

echo ""
echo -e "  ${BOLD}╔═══════════════════════════════════════════════════╗${NC}"
echo -e "  ${BOLD}║  ChainSight — IBM Bob Supply Chain Scanner        ║${NC}"
echo -e "  ${BOLD}╚═══════════════════════════════════════════════════╝${NC}"
echo ""

# Find requirements.txt
REQ_FILE=""
for f in $(git diff --cached --name-only --diff-filter=ACM 2>/dev/null); do
    [[ "$f" == *"requirements.txt"* ]] && REQ_FILE="$f"
done
[ -z "$REQ_FILE" ] && [ -f "requirements.txt" ] && REQ_FILE="requirements.txt"

if [ -z "$REQ_FILE" ]; then
    echo -e "  ${GREEN}✓  No dependency files in commit — approved${NC}"
    exit 0
fi

echo -e "  📦 Found: $REQ_FILE"

# Parse requirements to JSON
PACKAGES=$(python3 -c "
import re, json, sys
packages = []
try:
    with open('$REQ_FILE') as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#') or line.startswith('-'):
                continue
            m = re.match(r'^([\w.-]+)==([\d.a-zA-Z]+)', line)
            if m:
                packages.append({'name': m.group(1), 'version': m.group(2), 'ecosystem': 'PyPI'})
            else:
                m2 = re.match(r'^([\w.-]+)', line)
                if m2 and len(m2.group(1)) > 1:
                    packages.append({'name': m2.group(1), 'version': 'unknown', 'ecosystem': 'PyPI'})
except Exception as e:
    pass
print(json.dumps(packages))
" 2>/dev/null)

COUNT=$(echo "$PACKAGES" | python3 -c "import sys,json;print(len(json.load(sys.stdin)))" 2>/dev/null || echo "0")

if [ "$COUNT" -eq "0" ]; then
    echo -e "  ${GREEN}✓  No packages found — approved${NC}"
    exit 0
fi

echo -e "  🔍 Scanning $COUNT packages against OSV.dev..."
echo ""

# Run blind spot checker
RESULT=$(echo "$PACKAGES" | python3 "$CHECKER" 2>/dev/null)

if [ -z "$RESULT" ]; then
    echo -e "  ${YELLOW}⚠  Scan failed — allowing commit${NC}"
    exit 0
fi

TOTAL=$(echo "$RESULT" | python3 -c "import sys,json;d=json.load(sys.stdin);print(d['total'])" 2>/dev/null || echo "0")
BLIND=$(echo "$RESULT" | python3 -c "import sys,json;d=json.load(sys.stdin);print(d['blind_count'])" 2>/dev/null || echo "0")

if [ "$TOTAL" -eq "0" ]; then
    echo -e "  ${GREEN}✓  No CVEs found in $COUNT packages${NC}"
    echo -e "  ${GREEN}✓  Commit approved${NC}"
    exit 0
fi

# Display CVEs
echo "$RESULT" | python3 -c "
import sys, json
data = json.load(sys.stdin)
blind_ids = {b['id'] for b in data['blind_spots']}
seen = set()
for cve in data['all_cves']:
    key = cve['id'] + cve['package']
    if key in seen:
        continue
    seen.add(key)
    is_blind = cve['id'] in blind_ids
    if is_blind:
        print(f\"  \033[0;35m\033[1m👁  BOB BLIND SPOT — {cve['id']}\033[0m\")
        print(f\"  \033[0;35m    Package : {cve['package']}=={cve['version']}\033[0m\")
        print(f\"  \033[0;35m    Published: {cve['pub_date']} ({cve['days_after']} days after Bob cutoff)\033[0m\")
        print(f\"  \033[0;35m    Bob had NO knowledge of this CVE at generation time\033[0m\")
    else:
        print(f\"  \033[1;33m⚠   {cve['id']} in {cve['package']}=={cve['version']}\033[0m\")
        print(f\"  \033[0;90m    Published: {cve['pub_date']} — Bob was trained with this CVE\033[0m\")
    print()
" 2>/dev/null

if [ "$BLIND" -gt "0" ]; then
    echo -e "  ${RED}${BOLD}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "  ${RED}${BOLD}║       COMMIT BLOCKED — BOB BLIND SPOT DETECTED       ║${NC}"
    echo -e "  ${RED}${BOLD}╚══════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${RED}$BLIND CVE(s) published AFTER Bob's training cutoff (2024-11-01)${NC}"
    echo -e "  ${RED}Bob could NOT warn about these when generating your code.${NC}"
    echo -e "  ${RED}Shipping violates EU Cyber Resilience Act Article 13.${NC}"
    echo ""
    echo -e "  ${BOLD}To proceed: upgrade vulnerable packages and re-commit${NC}"
    echo -e "  ${YELLOW}  Bypass (not recommended): git commit --no-verify${NC}"
    echo ""
    exit 1
else
    echo -e "  ${YELLOW}⚠  $TOTAL CVE(s) found — all known to Bob at generation time${NC}"
    echo -e "  ${GREEN}✓  No blind spots — commit allowed${NC}"
    echo -e "  ${YELLOW}  Manual review recommended before deploying${NC}"
    echo ""
    exit 0
fi
